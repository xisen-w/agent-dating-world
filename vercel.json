{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/handler?__route=/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "/api/handler?__route=/auth/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/handler.ts": {
      "maxDuration": 300
    }
  }
}
