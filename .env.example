# Aicoo deployment the app runs against.
# Use http://localhost:3000 only when developing against the sibling pulse repo.
AICOO_BASE_URL=https://www.aicoo.io

# OAuth client. Leave empty to let the BFF self-register via Aicoo's
# dynamic client registration on first login (cached in .oauth-client.json).
AICOO_CLIENT_ID=
AICOO_CLIENT_SECRET=
AICOO_REDIRECT_URI=http://localhost:8787/auth/callback

# Long random string for encrypting the session cookie.
SESSION_SECRET=change-me-to-a-long-random-string

# Separate pepper for opaque player IDs and synthetic-vault commitments.
ARENA_SECRET=change-me-to-a-different-long-random-string

# Arena operator: an Aicoo account whose workspace stores the roster and proof ledger.
AICOO_OPERATOR_API_KEY=

PORT=8787
SPA_URL=http://localhost:3000
