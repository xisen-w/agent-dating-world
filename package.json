{
  "name": "virtual-n1-world",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "start": "tsx server/src/index.ts",
    "build": "tsc --noEmit && tsc -p server --noEmit && vite build",
    "typecheck:server": "tsc -p server --noEmit",
    "test": "tsx --test server/src/*.test.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "tsx": "^4.19.2",
    "vite": "^6.0.5",
    "typescript": "^5.7.2"
  }
}
